{
  "manifest_version": 3,
  "name": "SurfDiary",
  "version": "1.0",
  "description": "A seamless, browser-integrated memo and diary tool.",
  "action": {
    "default_title": "SurfDiary"
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "contextMenus",
    "downloads",
    "sidePanel",
    "tabs",
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
